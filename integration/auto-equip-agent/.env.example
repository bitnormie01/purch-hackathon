# Auto-Equip Agent — Environment Variables
# Copy this to .env and fill in your values.

# Your Solana wallet secret key (base58-encoded, 64 bytes).
# This wallet MUST be funded with USDC on Solana mainnet.
WALLET_SECRET_KEY=your_base58_encoded_secret_key_here

# Your Solana wallet public address (base58).
WALLET_ADDRESS=your_solana_wallet_address_here

# Email for purchase confirmations from Purch.
EMAIL=agent@example.com

# Optional: Maximum budget in USDC per item (default: 5.00)
MAX_BUDGET_PER_ITEM=5.00
